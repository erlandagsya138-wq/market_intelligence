# ============================================================
# .env — Market Intelligence Agent (SerpApi Raw JSON Fetcher)
# Salin ke .env dan isi nilainya. JANGAN commit .env ke Git!
# ============================================================

# ── App ──────────────────────────────────────────────────────
APP_NAME="Market Intelligence Agent"
APP_VERSION="1.0.0"
DEBUG=false

# ── Security ─────────────────────────────────────────────────
# Generate: python -c "import secrets; print(secrets.token_hex(32))"
API_KEY="ganti-dengan-key-acak-yang-kuat"

# ── SerpApi ──────────────────────────────────────────────────
SERPAPI_KEY="your-serpapi-key-here"
SERPAPI_TIMEOUT_SEC=30
SERPAPI_MAX_RETRIES=2
SERPAPI_RETRY_DELAY_SEC=2.0
SERPAPI_CONCURRENT_LIMIT=2

# ── Penyimpanan JSON ─────────────────────────────────────────
# Direktori output hasil scraping (relatif dari root project)
DATA_DIR="data/runs"

# Berapa run terakhir yang disimpan (0 = simpan semua, tidak ada hapus otomatis)
DATA_MAX_RUNS_KEPT=30

# ── Scheduler ────────────────────────────────────────────────
CRON_HOUR=19
CRON_MINUTE=30
TIMEZONE="Asia/Jakarta"
SCHEDULER_DISABLED=false
